SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
FORNACAST_DATABASE_ADAPTER=turso
FORNACAST_DATABASE_PATH=/data/fornacast.db
FORNACAST_CONFIG_DATABASE_PATH=/data/fornacast_config.db
FORNACAST_BASE_URL=http://localhost:4000
FORNACAST_SSH_HOST=localhost
FORNACAST_SSH_PORT=2222

# Remote Turso/libSQL for the Ecto database, optional.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Remote Turso/libSQL for Concord-backed app config, optional.
FORNACAST_CONFIG_TURSO_DATABASE_URL=
FORNACAST_CONFIG_TURSO_AUTH_TOKEN=

# PostgreSQL, optional. Requires building with FORNACAST_DATABASE_ADAPTER=postgres.
DATABASE_URL=ecto://fornacast:change-me@db/fornacast_prod
POSTGRES_PASSWORD=change-me
